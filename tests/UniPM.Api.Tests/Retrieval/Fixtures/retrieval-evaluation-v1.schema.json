{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "retrieval-evaluation-v1.schema.json",
  "title": "UniPM Retrieval Evaluation Manifest v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "$schema",
    "evaluationVersion",
    "datasetVersion",
    "assetAnnotations",
    "recordAnnotations",
    "queries"
  ],
  "properties": {
    "$schema": {
      "const": "retrieval-evaluation-v1.schema.json"
    },
    "evaluationVersion": {
      "const": "1.1.0"
    },
    "datasetVersion": {
      "const": "1.1.0"
    },
    "assetAnnotations": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/assetAnnotation"
      }
    },
    "recordAnnotations": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/recordAnnotation"
      }
    },
    "queries": {
      "type": "array",
      "minItems": 20,
      "maxItems": 24,
      "items": {
        "$ref": "#/$defs/query"
      }
    }
  },
  "$defs": {
    "guid": {
      "type": "string",
      "format": "uuid"
    },
    "issueKey": {
      "type": "string",
      "pattern": "^[a-z0-9_]+$"
    },
    "scenarioTag": {
      "type": "string",
      "enum": [
        "same-asset-history",
        "similar-asset-fallback",
        "same-building-context",
        "recurring-issue",
        "resolved",
        "unresolved",
        "distractor",
        "different-category-distractor",
        "normal-operational",
        "retrieval-relevant",
        "lexicon-covered",
        "semantic-paraphrase",
        "checklist-work-done",
        "english",
        "tagalog",
        "taglish"
      ]
    },
    "assetAnnotation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "assetId",
        "assetCode",
        "tags"
      ],
      "properties": {
        "assetId": {
          "$ref": "#/$defs/guid"
        },
        "assetCode": {
          "type": "string",
          "pattern": "^(FE|FA|EL|WDS)-\\d{3}$"
        },
        "tags": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "const": "cold-start"
          }
        }
      }
    },
    "recordAnnotation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "inspectionId",
        "inspectionSeedKey",
        "expectedIssueKeys",
        "scenarioTags"
      ],
      "properties": {
        "inspectionId": {
          "$ref": "#/$defs/guid"
        },
        "inspectionSeedKey": {
          "type": "string",
          "minLength": 1
        },
        "expectedIssueKeys": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/issueKey"
          }
        },
        "scenarioTags": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/scenarioTag"
          }
        }
      }
    },
    "query": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "queryId",
        "queryText",
        "language",
        "assetCategory",
        "retrievalFilters",
        "expectedRelevantInspectionIds",
        "scenarioTags",
        "notes"
      ],
      "properties": {
        "queryId": {
          "type": "string",
          "pattern": "^Q[0-9]{3}$"
        },
        "queryText": {
          "type": "string",
          "minLength": 1,
          "maxLength": 256
        },
        "language": {
          "type": "string",
          "enum": [
            "english",
            "tagalog",
            "taglish"
          ]
        },
        "assetCategory": {
          "type": "string",
          "enum": [
            "fire-extinguisher",
            "fire-alarm",
            "emergency-light",
            "water-drinking-station"
          ]
        },
        "contextAssetId": {
          "$ref": "#/$defs/guid"
        },
        "retrievalFilters": {
          "$ref": "#/$defs/retrievalFilters"
        },
        "expectedRelevantInspectionIds": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/guid"
          }
        },
        "scenarioTags": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "enum": [
              "same-asset-history",
              "similar-asset-fallback",
              "cold-start",
              "lexicon-covered",
              "semantic-paraphrase",
              "distractor-resistance",
              "same-building-context",
              "cross-language",
              "resolved-history",
              "unresolved-history"
            ]
          }
        },
        "notes": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "retrievalFilters": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "assetId": {
          "$ref": "#/$defs/guid"
        },
        "assetCategory": {
          "enum": [
            "fire-extinguisher",
            "fire-alarm",
            "emergency-light",
            "water-drinking-station"
          ]
        },
        "building": {
          "type": "string",
          "maxLength": 256
        },
        "department": {
          "type": "string",
          "maxLength": 256
        },
        "location": {
          "type": "string",
          "maxLength": 256
        },
        "isOperational": {
          "type": "boolean"
        },
        "dateFrom": {
          "type": "string",
          "format": "date-time"
        },
        "dateTo": {
          "type": "string",
          "format": "date-time"
        }
      }
    }
  }
}
