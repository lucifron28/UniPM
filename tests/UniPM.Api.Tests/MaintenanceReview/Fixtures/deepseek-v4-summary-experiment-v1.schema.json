{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://unipm.local/schemas/deepseek-v4-summary-experiment-v1.schema.json",
  "title": "UniPM DeepSeek V4 summary experiment manifest",
  "type": "object",
  "additionalProperties": false,
  "required": ["manifestVersion", "datasetVersion", "targetProvider", "targetModel", "thinkingMode", "cases"],
  "properties": {
    "manifestVersion": { "const": "1.0.0" },
    "datasetVersion": { "const": "1.1.0" },
    "targetProvider": { "const": "deepseek" },
    "targetModel": { "const": "deepseek-v4-flash" },
    "thinkingMode": { "const": "disabled" },
    "cases": {
      "type": "array",
      "minItems": 12,
      "maxItems": 12,
      "items": { "$ref": "#/$defs/case" }
    }
  },
  "$defs": {
    "case": {
      "type": "object",
      "additionalProperties": false,
      "required": ["caseId", "language", "assetId", "findingText", "expectedEvidenceCondition", "recurrenceMayBeStated", "forbiddenUnsupportedClaims", "manualReviewNotes"],
      "properties": {
        "caseId": { "type": "string", "pattern": "^DSV4-(EN|TL|TG)-[0-9]{3}$" },
        "language": { "enum": ["english", "tagalog", "taglish"] },
        "assetId": { "type": "string", "format": "uuid" },
        "findingText": { "type": "string", "minLength": 1, "maxLength": 2000 },
        "expectedEvidenceCondition": { "enum": ["same_asset_history_found", "similar_asset_fallback", "same_category_fallback"] },
        "recurrenceMayBeStated": { "type": "boolean" },
        "forbiddenUnsupportedClaims": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "type": "string", "minLength": 1, "maxLength": 256 }
        },
        "manualReviewNotes": { "type": "string", "minLength": 1, "maxLength": 1000 },
        "testSetup": { "enum": ["prompt-injection-source"] }
      }
    }
  }
}
