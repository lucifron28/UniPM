      "get": {
        "tags": ["Schedules"],
        "summary": "Lists preventive maintenance schedules using supported filters",
        "operationId": "ListSchedules",
        "parameters": [
          {
            "name": "assetId",
            "in": "query",
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          },
          {
            "name": "status",
            "in": "query",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "from",
            "in": "query",
            "schema": {
              "type": "string",
              "format": "date-time"
