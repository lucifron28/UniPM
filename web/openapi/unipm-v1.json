          }
        }
      },
      "AuthUserResponse": {
        "required": ["id", "email", "displayName", "roles"],
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid"
          },
          "email": {
            "type": "string"
          },
          "displayName": {
            "type": "string"
          },
          "roles": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      },
      "CreateAssetDto": {
        "type": "object",
        "properties": {
          "assetCode": {
            "type": "string"
          },
          "assetCategory": {
            "type": "string"
          },
          "building": {
            "type": ["null", "string"]
          },
          "department": {
            "type": ["null", "string"]
          },
          "location": {
            "type": ["null", "string"]
          }
        }
      },
      "CreateScheduleDto": {
        "type": "object",
        "properties": {
          "assetId": {
