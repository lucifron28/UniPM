        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid"
          },
          "assetCode": {
            "type": "string"
          },
          "assetCategory": {
            "type": "string"
          },
          "building": {
            "type": ["null", "string"]
          },
          "department": {
            "type": ["null", "string"]
          },
          "location": {
            "type": ["null", "string"]
          },
          "qrCodeValue": {
