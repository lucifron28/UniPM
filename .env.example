# Copy this file to .env for local Docker Compose development.
# Replace the password before using the environment beyond local development.
MSSQL_SA_PASSWORD=ChangeThisLocalPassword123!
UNIPM_DB_NAME=UniPMDb
UNIPM_DB_PORT=1433
UNIPM_API_PORT=5000
# Local Docker development override; committed appsettings remain disabled.
UNIPM_METRICS_ENABLED=true
UNIPM_PROMETHEUS_PORT=9090
UNIPM_GRAFANA_PORT=3000
UNIPM_GRAFANA_ADMIN_USER=admin
# Local development only. Change this before using Grafana beyond a local machine.
UNIPM_GRAFANA_ADMIN_PASSWORD=ChangeThisLocalGrafanaPassword123!

# Local source-only maintenance review. Keep summary generation disabled until
# a provider has been configured and the sanitized prompt has been inspected.
UNIPM_MAINTENANCE_REVIEW_ENABLED=true
UNIPM_SUMMARY_ENABLED=false
UNIPM_SUMMARY_PROVIDER_KEY=
UNIPM_SUMMARY_BASE_ADDRESS=
UNIPM_SUMMARY_PATH=/v1/chat/completions
UNIPM_SUMMARY_MODEL=
UNIPM_SUMMARY_API_KEY=
UNIPM_SUMMARY_TIMEOUT_SECONDS=30
UNIPM_SUMMARY_MAX_PROMPT_CHARACTERS=12000
UNIPM_SUMMARY_MAX_OUTPUT_CHARACTERS=4000
UNIPM_SUMMARY_MAX_SOURCE_TEXT_CHARACTERS=1500
UNIPM_SUMMARY_ALLOW_REMOTE_PROVIDER=false

# Optional semantic embeddings. Disabled by default; API keys belong only here
# or in the process environment, never in committed appsettings files.
UNIPM_EMBEDDINGS_ENABLED=false
UNIPM_EMBEDDINGS_PROVIDER_KEY=
UNIPM_EMBEDDINGS_BASE_ADDRESS=
UNIPM_EMBEDDINGS_PATH=/v1/embeddings
UNIPM_EMBEDDINGS_MODEL=
UNIPM_EMBEDDINGS_API_KEY=
UNIPM_EMBEDDINGS_DIMENSIONS=
UNIPM_EMBEDDINGS_TIMEOUT_SECONDS=30
UNIPM_EMBEDDINGS_MAX_BATCH_SIZE=16
UNIPM_EMBEDDINGS_MAX_INPUT_CHARACTERS=4000
UNIPM_EMBEDDINGS_ALLOW_REMOTE_PROVIDER=false

# Optional real-provider smoke test; never commit real credentials.
# UNIPM_EMBEDDING_TEST_ENDPOINT=
# UNIPM_EMBEDDING_TEST_MODEL=
# UNIPM_EMBEDDING_TEST_API_KEY=
# UNIPM_EMBEDDING_TEST_DIMENSIONS=
