{
    "$schema":  "https://json-schema.org/draft/2020-12/schema",
    "$id":  "synthetic-maintenance-v1.schema.json",
    "title":  "UniPM Synthetic Preventive Maintenance Dataset v1",
    "type":  "object",
    "additionalProperties":  false,
    "required":  [
                     "datasetVersion",
                     "title",
                     "description",
                     "createdAt",
                     "expectedCounts",
                     "sourceBasis",
                     "assumptions",
                     "actors",
                     "assets",
                     "schedules",
                     "inspections"
                 ],
    "properties":  {
                       "$schema":  {
                                       "type":  "string"
                                   },
                       "datasetVersion":  {
                                              "type":  "string",
                                              "pattern":  "^\\d+\\.\\d+\\.\\d+$"
                                          },
                       "title":  {
                                     "type":  "string",
                                     "minLength":  1
                                 },
                       "description":  {
                                           "type":  "string",
                                           "minLength":  1
                                       },
                       "createdAt":  {
                                         "type":  "string",
                                         "format":  "date-time"
                                     },
                       "expectedCounts":  {
                                              "type":  "object",
                                              "additionalProperties":  false,
                                              "required":  [
                                                               "actors",
                                                               "assets",
                                                               "schedules",
                                                               "inspections"
                                                           ],
                                              "properties":  {
                                                                 "actors":  {
                                                                                "type":  "integer",
                                                                                "minimum":  1
                                                                            },
                                                                 "assets":  {
                                                                                "type":  "integer",
                                                                                "minimum":  1
                                                                            },
                                                                 "schedules":  {
                                                                                   "type":  "integer",
                                                                                   "minimum":  1
                                                                               },
                                                                 "inspections":  {
                                                                                     "type":  "integer",
                                                                                     "minimum":  1
                                                                                 }
                                                             }
                                          },
                       "sourceBasis":  {
                                           "type":  "array",
                                           "minItems":  4,
                                           "items":  {
                                                         "$ref":  "#/$defs/sourceBasis"
                                                     }
                                       },
                       "assumptions":  {
                                           "type":  "array",
                                           "minItems":  1,
                                           "items":  {
                                                         "type":  "string",
                                                         "minLength":  1
                                                     }
                                       },
                       "actors":  {
                                      "type":  "array",
                                      "minItems":  1,
                                      "items":  {
                                                    "$ref":  "#/$defs/actor"
                                                }
                                  },
                       "assets":  {
                                      "type":  "array",
                                      "minItems":  4,
                                      "items":  {
                                                    "$ref":  "#/$defs/asset"
                                                }
                                  },
                       "schedules":  {
                                         "type":  "array",
                                         "minItems":  1,
                                         "items":  {
                                                       "$ref":  "#/$defs/schedule"
                                                   }
                                     },
                       "inspections":  {
                                           "type":  "array",
                                           "minItems":  1,
                                           "items":  {
                                                         "$ref":  "#/$defs/inspection"
                                                     }
                                       }
                   },
    "$defs":  {
                  "guid":  {
                               "type":  "string",
                               "format":  "uuid"
                           },
                  "nullableString":  {
                                         "type":  [
                                                      "string",
                                                      "null"
                                                  ]
                                     },
                  "nullableDate":  {
                                       "type":  [
                                                    "string",
                                                    "null"
                                                ],
                                       "format":  "date"
                                   },
                  "nullableDateTime":  {
                                           "type":  [
                                                        "string",
                                                        "null"
                                                    ],
                                           "format":  "date-time"
                                       },
                  "assetCategory":  {
                                        "type":  "string",
                                        "enum":  [
                                                     "fire-extinguisher",
                                                     "fire-alarm",
                                                     "emergency-light",
                                                     "water-drinking-station"
                                                 ]
                                    },
                  "sourceBasis":  {
                                      "type":  "object",
                                      "additionalProperties":  false,
                                      "required":  [
                                                       "assetCategory",
                                                       "formTitle",
                                                       "pageObserved",
                                                       "revision",
                                                       "effectivityDate",
                                                       "documentCode"
                                                   ],
                                      "properties":  {
                                                         "assetCategory":  {
                                                                               "$ref":  "#/$defs/assetCategory"
                                                                           },
                                                         "formTitle":  {
                                                                           "type":  "string",
                                                                           "minLength":  1
                                                                       },
                                                         "pageObserved":  {
                                                                              "type":  "string",
                                                                              "minLength":  1
                                                                          },
                                                         "revision":  {
                                                                          "type":  "string",
                                                                          "minLength":  1
                                                                      },
                                                         "effectivityDate":  {
                                                                                 "type":  "string",
                                                                                 "pattern":  "^\\d{4}-\\d{2}$"
                                                                             },
                                                         "documentCode":  {
                                                                              "$ref":  "#/$defs/nullableString"
                                                                          }
                                                     }
                                  },
                  "actor":  {
                                "type":  "object",
                                "additionalProperties":  false,
                                "required":  [
                                                 "seedKey",
                                                 "id",
                                                 "roleToken",
                                                 "displayLabel"
                                             ],
                                "properties":  {
                                                   "seedKey":  {
                                                                   "type":  "string",
                                                                   "minLength":  1
                                                               },
                                                   "id":  {
                                                              "$ref":  "#/$defs/guid"
                                                          },
                                                   "roleToken":  {
                                                                     "type":  "string",
                                                                     "enum":  [
                                                                                  "GSD_FIRE_INSPECTOR",
                                                                                  "ELECTRICAL_ENGINEER",
                                                                                  "PLUMBER",
                                                                                  "PPF_SUPERVISOR",
                                                                                  "DEPARTMENT_HEAD"
                                                                              ]
                                                                 },
                                                   "displayLabel":  {
                                                                        "type":  "string",
                                                                        "minLength":  1
                                                                    }
                                               }
                            },
                  "asset":  {
                                "type":  "object",
                                "additionalProperties":  false,
                                "required":  [
                                                 "seedKey",
                                                 "id",
                                                 "assetCode",
                                                 "assetCategory",
                                                 "building",
                                                 "department",
                                                 "location",
                                                 "status",
                                                 "categoryDetails",
                                                 "qrCodeValue"
                                             ],
                                "properties":  {
                                                   "seedKey":  {
                                                                   "type":  "string",
                                                                   "minLength":  1
                                                               },
                                                   "id":  {
                                                              "$ref":  "#/$defs/guid"
                                                          },
                                                   "assetCode":  {
                                                                     "type":  "string",
                                                                     "pattern":  "^(FE|FA|EL|WDS)-\\d{3}$"
                                                                 },
                                                   "assetCategory":  {
                                                                         "$ref":  "#/$defs/assetCategory"
                                                                     },
                                                   "building":  {
                                                                    "type":  "string",
                                                                    "minLength":  1
                                                                },
                                                   "department":  {
                                                                      "type":  "string",
                                                                      "minLength":  1
                                                                  },
                                                   "location":  {
                                                                    "type":  "string",
                                                                    "minLength":  1
                                                                },
                                                   "status":  {
                                                                  "type":  "string",
                                                                  "enum":  [
                                                                               "Active",
                                                                               "Inactive",
                                                                               "Retired"
                                                                           ]
                                                              },
                                                   "categoryDetails":  {
                                                                           "type":  "object"
                                                                       },
                                                   "qrCodeValue":  {
                                                                       "type":  "string",
                                                                       "pattern":  "^UNIPM-[A-Z-]+-[0-9A-F]{8}$"
                                                                   }
                                               },
                                "allOf":  [
                                              {
                                                  "if":  {
                                                             "properties":  {
                                                                                "assetCategory":  {
                                                                                                      "const":  "fire-extinguisher"
                                                                                                  }
                                                                            }
                                                         },
                                                  "then":  {
                                                               "properties":  {
                                                                                  "categoryDetails":  {
                                                                                                          "$ref":  "#/$defs/fireExtinguisherDetails"
                                                                                                      }
                                                                              }
                                                           }
                                              },
                                              {
                                                  "if":  {
                                                             "properties":  {
                                                                                "assetCategory":  {
                                                                                                      "const":  "fire-alarm"
                                                                                                  }
                                                                            }
                                                         },
                                                  "then":  {
                                                               "properties":  {
                                                                                  "categoryDetails":  {
                                                                                                          "$ref":  "#/$defs/fireAlarmDetails"
                                                                                                      }
                                                                              }
                                                           }
                                              },
                                              {
                                                  "if":  {
                                                             "properties":  {
                                                                                "assetCategory":  {
                                                                                                      "const":  "emergency-light"
                                                                                                  }
                                                                            }
                                                         },
                                                  "then":  {
                                                               "properties":  {
                                                                                  "categoryDetails":  {
                                                                                                          "$ref":  "#/$defs/emergencyLightDetails"
                                                                                                      }
                                                                              }
                                                           }
                                              },
                                              {
                                                  "if":  {
                                                             "properties":  {
                                                                                "assetCategory":  {
                                                                                                      "const":  "water-drinking-station"
                                                                                                  }
                                                                            }
                                                         },
                                                  "then":  {
                                                               "properties":  {
                                                                                  "categoryDetails":  {
                                                                                                          "$ref":  "#/$defs/waterStationDetails"
                                                                                                      }
                                                                              }
                                                           }
                                              }
                                          ]
                            },
                  "fireExtinguisherDetails":  {
                                                  "type":  "object",
                                                  "additionalProperties":  false,
                                                  "required":  [
                                                                   "type",
                                                                   "capacity",
                                                                   "expirationDate"
                                                               ],
                                                  "properties":  {
                                                                     "type":  {
                                                                                  "type":  "string",
                                                                                  "minLength":  1
                                                                              },
                                                                     "capacity":  {
                                                                                      "type":  "string",
                                                                                      "minLength":  1
                                                                                  },
                                                                     "expirationDate":  {
                                                                                            "type":  "string",
                                                                                            "format":  "date"
                                                                                        }
                                                                 }
                                              },
                  "fireAlarmDetails":  {
                                           "type":  "object",
                                           "additionalProperties":  false,
                                           "required":  [
                                                            "deviceParticulars",
                                                            "deviceType"
                                                        ],
                                           "properties":  {
                                                              "deviceParticulars":  {
                                                                                        "type":  "string",
                                                                                        "minLength":  1
                                                                                    },
                                                              "deviceType":  {
                                                                                 "type":  "string",
                                                                                 "minLength":  1
                                                                             }
                                                          }
                                       },
                  "emergencyLightDetails":  {
                                                "type":  "object",
                                                "additionalProperties":  false,
                                                "required":  [
                                                                 "dateInstalled",
                                                                 "unitType"
                                                             ],
                                                "properties":  {
                                                                   "dateInstalled":  {
                                                                                         "type":  "string",
                                                                                         "format":  "date"
                                                                                     },
                                                                   "unitType":  {
                                                                                    "type":  "string",
                                                                                    "minLength":  1
                                                                                }
                                                               }
                                            },
                  "waterStationDetails":  {
                                              "type":  "object",
                                              "additionalProperties":  false,
                                              "required":  [
                                                               "stationType",
                                                               "filterConfiguration",
                                                               "hasUvLight"
                                                           ],
                                              "properties":  {
                                                                 "stationType":  {
                                                                                     "type":  "string",
                                                                                     "minLength":  1
                                                                                 },
                                                                 "filterConfiguration":  {
                                                                                             "type":  "array",
                                                                                             "minItems":  1,
                                                                                             "items":  {
                                                                                                           "type":  "string",
                                                                                                           "minLength":  1
                                                                                                       },
                                                                                             "uniqueItems":  true
                                                                                         },
                                                                 "hasUvLight":  {
                                                                                    "type":  "boolean"
                                                                                }
                                                             }
                                          },
                  "schedule":  {
                                   "type":  "object",
                                   "additionalProperties":  false,
                                   "required":  [
                                                    "seedKey",
                                                    "id",
                                                    "assetId",
                                                    "assetCode",
                                                    "scheduleDate",
                                                    "periodType",
                                                    "quarter",
                                                    "semester",
                                                    "year",
                                                    "academicYear",
                                                    "status",
                                                    "assignedToUserId",
                                                    "completedAt"
                                                ],
                                   "properties":  {
                                                      "seedKey":  {
                                                                      "type":  "string",
                                                                      "minLength":  1
                                                                  },
                                                      "id":  {
                                                                 "$ref":  "#/$defs/guid"
                                                             },
                                                      "assetId":  {
                                                                      "$ref":  "#/$defs/guid"
                                                                  },
                                                      "assetCode":  {
                                                                        "type":  "string",
                                                                        "pattern":  "^(FE|FA|EL|WDS)-\\d{3}$"
                                                                    },
                                                      "scheduleDate":  {
                                                                           "type":  "string",
                                                                           "format":  "date"
                                                                       },
                                                      "periodType":  {
                                                                         "type":  "string",
                                                                         "enum":  [
                                                                                      "Quarter",
                                                                                      "Semester",
                                                                                      "Annual",
                                                                                      "Custom"
                                                                                  ]
                                                                     },
                                                      "quarter":  {
                                                                      "type":  [
                                                                                   "string",
                                                                                   "null"
                                                                               ],
                                                                      "enum":  [
                                                                                   "Q1",
                                                                                   "Q2",
                                                                                   "Q3",
                                                                                   "Q4",
                                                                                   null
                                                                               ]
                                                                  },
                                                      "semester":  {
                                                                       "type":  [
                                                                                    "string",
                                                                                    "null"
                                                                                ],
                                                                       "enum":  [
                                                                                    "First",
                                                                                    "Second",
                                                                                    "Summer",
                                                                                    null
                                                                                ]
                                                                   },
                                                      "year":  {
                                                                   "type":  [
                                                                                "integer",
                                                                                "null"
                                                                            ],
                                                                   "minimum":  2000,
                                                                   "maximum":  2100
                                                               },
                                                      "academicYear":  {
                                                                           "type":  [
                                                                                        "string",
                                                                                        "null"
                                                                                    ],
                                                                           "pattern":  "^\\d{4}-\\d{4}$"
                                                                       },
                                                      "status":  {
                                                                     "type":  "string",
                                                                     "enum":  [
                                                                                  "Due",
                                                                                  "Ongoing",
                                                                                  "Completed",
                                                                                  "Overdue",
                                                                                  "Cancelled"
                                                                              ]
                                                                 },
                                                      "assignedToUserId":  {
                                                                               "$ref":  "#/$defs/guid"
                                                                           },
                                                      "completedAt":  {
                                                                          "$ref":  "#/$defs/nullableDateTime"
                                                                      }
                                                  }
                               },
                  "inspection":  {
                                     "type":  "object",
                                     "additionalProperties":  false,
                                     "required":  [
                                                      "seedKey",
                                                      "id",
                                                      "scheduleId",
                                                      "assetId",
                                                      "assetCode",
                                                      "assetCategory",
                                                      "inspectorUserId",
                                                      "dateInspected",
                                                      "isOperational",
                                                      "remarks",
                                                      "actionsRecommendations",
                                                      "formData"
                                                  ],
                                     "properties":  {
                                                        "seedKey":  {
                                                                        "type":  "string",
                                                                        "minLength":  1
                                                                    },
                                                        "id":  {
                                                                   "$ref":  "#/$defs/guid"
                                                               },
                                                        "scheduleId":  {
                                                                           "$ref":  "#/$defs/guid"
                                                                       },
                                                        "assetId":  {
                                                                        "$ref":  "#/$defs/guid"
                                                                    },
                                                        "assetCode":  {
                                                                          "type":  "string",
                                                                          "pattern":  "^(FE|FA|EL|WDS)-\\d{3}$"
                                                                      },
                                                        "assetCategory":  {
                                                                              "$ref":  "#/$defs/assetCategory"
                                                                          },
                                                        "inspectorUserId":  {
                                                                                "$ref":  "#/$defs/guid"
                                                                            },
                                                        "dateInspected":  {
                                                                              "type":  "string",
                                                                              "format":  "date-time"
                                                                          },
                                                        "isOperational":  {
                                                                              "type":  "boolean"
                                                                          },
                                                        "remarks":  {
                                                                        "type":  "string",
                                                                        "minLength":  1,
                                                                        "maxLength":  2000
                                                                    },
                                                        "actionsRecommendations":  {
                                                                                       "type":  "string",
                                                                                       "minLength":  1,
                                                                                       "maxLength":  2000
                                                                                   },
                                                        "formData":  {
                                                                         "$ref":  "#/$defs/formData"
                                                                     }
                                                    }
                                 },
                  "formData":  {
                                   "type":  "object",
                                   "additionalProperties":  false,
                                   "properties":  {
                                                      "workDone":  {
                                                                       "type":  "array",
                                                                       "items":  {
                                                                                     "type":  "string",
                                                                                     "minLength":  1
                                                                                 },
                                                                       "uniqueItems":  true
                                                                   },
                                                      "rmrfNumber":  {
                                                                         "$ref":  "#/$defs/nullableString"
                                                                     },
                                                      "dateAccomplished":  {
                                                                               "$ref":  "#/$defs/nullableDate"
                                                                           },
                                                      "acknowledgedByRole":  {
                                                                                 "$ref":  "#/$defs/nullableString"
                                                                             },
                                                      "notedByRole":  {
                                                                          "$ref":  "#/$defs/nullableString"
                                                                      }
                                                  }
                               }
              }
}
