{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "maintenance-issue-lexicon-v1.schema.json",
  "title": "UniPM Maintenance Issue Lexicon v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "$schema",
    "lexiconVersion",
    "issues"
  ],
  "properties": {
    "$schema": {
      "const": "maintenance-issue-lexicon-v1.schema.json"
    },
    "lexiconVersion": {
      "const": "1.0.0"
    },
    "issues": {
      "type": "array",
      "minItems": 11,
      "maxItems": 11,
      "items": {
        "$ref": "#/$defs/issue"
      }
    }
  },
  "$defs": {
    "issue": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "key",
        "assetCategory",
        "aliases"
      ],
      "properties": {
        "key": {
          "type": "string",
          "enum": [
            "alarm_panel_fault",
            "battery_issue",
            "clogged_filter",
            "device_not_responding",
            "expired_unit",
            "leaking",
            "low_pressure",
            "not_lighting",
            "smoke_detector_issue",
            "uv_light_issue",
            "weak_water_flow"
          ]
        },
        "assetCategory": {
          "enum": [
            "fire-extinguisher",
            "fire-alarm",
            "emergency-light",
            "water-drinking-station"
          ]
        },
        "aliases": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    }
  }
}
